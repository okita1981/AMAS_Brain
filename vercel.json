{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/ai/*.ts": { "maxDuration": 60 },
    "api/workflow/*.ts": { "maxDuration": 60 },
    "api/campaigns/deploy.ts": { "maxDuration": 60 },
    "api/keywords/*.ts": { "maxDuration": 60 },
    "api/storage/upload.ts": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/((?!api/|assets/|.*\\..*).*)", "destination": "/index.html" }
  ]
}
