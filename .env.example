# .env.example

# === AI / LLM APIs ===
GEMINI_API_KEY=          # Google Gemini APIキー（フォールバック生成・KWボリューム推定）
ANTHROPIC_API_KEY=       # Claude APIキー（戦略立案・分析・各種ワークフロー）
OPENAI_API_KEY=          # OpenAI APIキー（コピー/バナー生成・KWサジェスト）

# === 決済（Stripe）===
STRIPE_SECRET_KEY=       # Stripe シークレットキー
STRIPE_WEBHOOK_SECRET=   # Stripe Webhook 署名シークレット

# === Firebase（サーバ側）===
FIREBASE_SERVICE_ACCOUNT_KEY=   # サービスアカウントJSON全体を文字列で（Firestore/Storage 初期化用）
# FIREBASE_STORAGE_BUCKET=      # 任意。未設定時は <project_id>.appspot.com

# === Google Ads API ===
# ベーシックアクセス審査中のため、本番接続までダミー値でデプロイ予定
GOOGLE_ADS_CLIENT_ID=           # OAuth 2.0 クライアントID（審査中／未接続）
GOOGLE_ADS_CLIENT_SECRET=       # OAuth 2.0 クライアントシークレット（審査中／未接続）
GOOGLE_ADS_DEVELOPER_TOKEN=     # Google Ads デベロッパートークン（ベーシックアクセス審査中）
GOOGLE_ADS_REFRESH_TOKEN=       # OAuth リフレッシュトークン（審査通過後に取得・未接続）

# === Meta（Facebook/Instagram）広告 API ===
# 現状未接続。接続までダミー値でデプロイ予定
META_APP_ID=                    # Meta アプリID（未接続）
META_APP_SECRET=                # Meta アプリシークレット（未接続）
META_ACCESS_TOKEN=              # Meta アクセストークン（未接続）

# === アプリ基底URL ===
# OAuth/Stripe コールバックURLの基底。Deploy後に確定URLへ更新すること
APP_URL=https://amas-brain.vercel.app
